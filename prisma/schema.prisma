generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id               String            @id @default(uuid())
  domain           String            @unique
  accessToken      String
  plan             Plan              @default(FREE)
  timezone         String?
  alertsEnabled    Boolean           @default(true)
  alertEmail       String?
  installedAt      DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  products         Product[]
  metricsSnapshots MetricsSnapshot[]
  settings         ShopSettings?
  purchaseOrders   PurchaseOrder[]
  processedOrders  ProcessedOrder[]
  alertSnoozes     AlertSnooze[]

  @@map("shops")
}

model ShopSettings {
  id                   String   @id @default(uuid())
  shopId               String   @unique
  ewmaAlpha            Float    @default(0.3)
  defaultLeadTimeDays  Float    @default(14)
  defaultServiceLevelZ Float    @default(1.645)
  syncFrequencyHours   Int      @default(12)
  updatedAt            DateTime @updatedAt
  shop                 Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("shop_settings")
}

model Product {
  id               String       @id @default(uuid())
  shopId           String
  shopifyProductId String
  shopifyVariantId String
  title            String
  sku              String
  currentStock     Int          @default(0)
  leadTimeDays     Float        @default(14)
  stockUpdatedAt   DateTime     @default(now())
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  dailySales       DailySale[]
  forecast         Forecast?
  snooze           AlertSnooze?
  shop             Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, shopifyVariantId])
  @@map("products")
}

model DailySale {
  id        String   @id @default(uuid())
  productId String
  date      DateTime @db.Date
  unitsSold Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, date])
  @@map("daily_sales")
}

model Forecast {
  id                   String         @id @default(uuid())
  productId            String         @unique
  velocityPerDay       Float
  stddevDemand         Float
  safetyStock          Float
  reorderPoint         Float
  daysOfStockRemaining Int?
  forecastAccuracy     Float?
  status               ForecastStatus @default(OK)
  calculatedAt         DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  product              Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("forecasts")
}

model MetricsSnapshot {
  id               String   @id @default(uuid())
  shopId           String
  snapshotDate     DateTime @db.Date
  critical         Int
  reorder          Int
  ok               Int
  total            Int
  forecastAccuracy Float?
  createdAt        DateTime @default(now())
  shop             Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, snapshotDate])
  @@map("metrics_snapshots")
}

model PurchaseOrder {
  id        String       @id @default(uuid())
  shopId    String
  reference String       @unique
  status    PoStatus     @default(DRAFT)
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  lineItems PoLineItem[]
  shop      Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("purchase_orders")
}

model ProcessedOrder {
  id             String   @id @default(uuid())
  shopId         String
  shopifyOrderId String
  processedAt    DateTime @default(now())
  shop           Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, shopifyOrderId])
  @@map("processed_orders")
}

model PoLineItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  unitCost        Float?
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@map("po_line_items")
}

model AlertSnooze {
  id                  String   @id @default(uuid())
  productId           String   @unique
  shopId              String
  expectedArrivalDate DateTime @db.Date
  snoozedAt           DateTime @default(now())
  product             Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  shop                Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("alert_snoozes")
}

enum Plan {
  FREE
  GROWTH
  PRO
}

enum ForecastStatus {
  OK
  REORDER
  CRITICAL
}

enum PoStatus {
  DRAFT
  SENT
  RECEIVED
}
